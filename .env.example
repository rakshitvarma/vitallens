GEMINI_API_KEY=your_ai_studio_key
# or use Vertex AI instead:
# GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_CLOUD_PROJECT=your-project
# GOOGLE_CLOUD_LOCATION=asia-south1
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
PUBLIC_BASE_URL=https://your-cloud-run-url

# Preferred: enable direct Google sign-in.
GOOGLE_CLIENT_ID=your-google-oauth-web-client-id.apps.googleusercontent.com
# Optional: force provider when both direct Google and Supabase are configured.
AUTH_PROVIDER=supabase

# Alternative: enable Google sign-in through Supabase Auth.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_or_publishable_key
